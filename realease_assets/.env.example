# If you change POSTGRES_DB, POSTGRES_USER, or POSTGRES_PASSWORD after the
# database volume has already been created, recreate the volume or update the
# credentials inside Postgres to match.
POSTGRES_DB=rstracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@postgres:5432/rstracker
SESSION_SECRET=replace-with-a-long-random-secret
PORT=3000
COOKIE_SECURE=1
