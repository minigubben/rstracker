# Copy this file to the repository root as .env before using the compose file.
# If you change POSTGRES_DB, POSTGRES_USER, or POSTGRES_PASSWORD after the
# database volume has already been created, recreate the volume or update the
# credentials inside Postgres to match.
POSTGRES_DB=rstracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
SESSION_SECRET=replace-with-a-long-random-secret
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=1
COOKIE_SECURE=1
