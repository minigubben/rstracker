{
  "name": "rstracker",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @rstracker/api --filter @rstracker/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @rstracker/api db:migrate",
    "create:user": "pnpm --filter @rstracker/api create:user"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
